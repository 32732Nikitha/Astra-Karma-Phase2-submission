{
  "name": "bhima-astra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:worker": "npm run build --prefix ../worker",
    "build:manager": "npm run build --prefix ../manager",
    "build:spas": "npm run build:worker && npm run build:manager && node scripts/copy-spa-builds.cjs",
    "build": "npm run build:spas && next build",
    "dev": "node scripts/ensure-spa.cjs && next dev",
    "dev:fresh": "npm run build:spas && next dev",
    "dev:next": "next dev",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.400.0",
    "next": "^16.2.2",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  }
}
