# Copy to .env locally. On Render, set these in the service "Environment" tab.

# Required — PostgreSQL (Render: Internal Database URL or External, from your Postgres instance)
# If the app fails to connect, try appending: ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional — comma-separated browser origins allowed to call the API (your Next.js URL on Render)
# Example: https://bhima-web.onrender.com
ALLOWED_ORIGINS=

# Optional — Redis (Render Redis or omit; API runs without it, WS/agents use fallbacks)
# REDIS_URL=redis://red-xxx:6379
